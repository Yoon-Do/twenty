# ===========================================
# PRODUCTION MULTI-TENANT CONFIGURATION
# ===========================================

# Environment
NODE_ENV=production
NODE_PORT=3000

# ===========================================
# MULTI-TENANT CONFIGURATION
# ===========================================
# Enable multi-workspace mode (production default)
SINGLE_WORKSPACE_MODE=false

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
PG_DATABASE_URL=postgres://postgres:postgres@localhost:5432/default
PG_SSL_ALLOW_SELF_SIGNED=false

# Redis Configuration  
REDIS_URL=redis://localhost:6379

# ClickHouse Configuration
#CLICKHOUSE_URL=http://default:devPassword@localhost:8123/default
#CLICKHOUSE_PASSWORD=devPassword

# ===========================================
# SECURITY CONFIGURATION (PRODUCTION)
# ===========================================
APP_SECRET=prod_app_secret_twenty_crm_$(openssl rand -hex 32)
ACCESS_TOKEN_SECRET=prod_access_token_$(openssl rand -hex 32)
LOGIN_TOKEN_SECRET=prod_login_token_$(openssl rand -hex 32)
REFRESH_TOKEN_SECRET=prod_refresh_token_$(openssl rand -hex 32)
FILE_TOKEN_SECRET=prod_file_token_$(openssl rand -hex 32)

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
FRONTEND_URL=http://localhost:3001

# ===========================================
# STORAGE CONFIGURATION (PRODUCTION)
# ===========================================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=.local-storage

# ===========================================
# MESSAGE QUEUE CONFIGURATION
# ===========================================
MESSAGE_QUEUE_TYPE=redis

# ===========================================
# LOGGING CONFIGURATION (PRODUCTION)
# ===========================================
LOGGER_LEVEL=warn
LOGGER_IS_BUFFER_ENABLED=true

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ORIGIN=http://localhost:3001

# ===========================================
# BILLING & SUBSCRIPTION (PRODUCTION)
# ===========================================
BILLING_PLAN_REQUIRED_LINK=https://twenty.com/pricing
BILLING_STRIPE_BASE_PLAN_PRODUCT_ID=prod_billing_base
BILLING_STRIPE_WEBHOOK_SECRET=

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
EMAIL_DRIVER=smtp
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# ===========================================
# AUTHENTICATION PROVIDERS
# ===========================================
AUTH_GOOGLE_ENABLED=false
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/redirect

AUTH_MICROSOFT_ENABLED=false
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
AUTH_MICROSOFT_CALLBACK_URL=http://localhost:3000/auth/microsoft/redirect

# ===========================================
# TELEMETRY & MONITORING (PRODUCTION)
# ===========================================
TELEMETRY_ENABLED=true
TELEMETRY_ANONYMIZATION_ENABLED=true
EXCEPTION_HANDLER_DRIVER=console

# ===========================================
# API CONFIGURATION
# ===========================================
API_RATE_LIMITING_TTL=60
API_RATE_LIMITING_REQUEST_COUNT=100

# ===========================================
# ADVANCED FEATURES
# ===========================================
CALENDAR_PROVIDER_GOOGLE_ENABLED=false
MESSAGING_PROVIDER_GMAIL_ENABLED=false
AI_INTEGRATION_ENABLED=false

# ===========================================
# WORKSPACE CONFIGURATION
# ===========================================
WORKSPACE_INACTIVE_DAYS_BEFORE_DELETION=90
WORKSPACE_INACTIVE_DAYS_BEFORE_NOTIFICATION=30

# ===========================================
# CACHE CONFIGURATION
# ===========================================
CACHE_TTL=3600
CACHE_MAX_ITEMS=1000

# ===========================================
# WORKSPACE MANAGEMENT (PRODUCTION)
# ===========================================
WORKSPACE_INACTIVE_DAYS_BEFORE_NOTIFICATION=7
WORKSPACE_INACTIVE_DAYS_BEFORE_SOFT_DELETION=30
WORKSPACE_INACTIVE_DAYS_BEFORE_DELETION=90

# ===========================================
# MULTI-TENANT FEATURE FLAGS
# ===========================================
IS_MULTIWORKSPACE_ENABLED=true
MAX_NUMBER_OF_WORKSPACES_DELETED_PER_EXECUTION=5
