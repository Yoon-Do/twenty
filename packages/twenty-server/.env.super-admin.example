# Super Admin Configuration
ENABLE_SUPER_ADMIN_MODE=true
SUPER_ADMIN_TOKEN_EXPIRY=3600
SUPER_ADMIN_ALLOWED_ORIGINS=localhost:3000,admin.yourcompany.com
SUPER_ADMIN_AUDIT_ENABLED=true

# Security Settings
SUPER_ADMIN_REQUIRE_MFA=false
SUPER_ADMIN_IP_WHITELIST=
SUPER_ADMIN_SESSION_TIMEOUT=86400

# Audit Configuration  
SUPER_ADMIN_AUDIT_RETENTION_DAYS=365
SUPER_ADMIN_LOG_LEVEL=HIGH
